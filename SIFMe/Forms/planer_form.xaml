<classes:form_controls x:Class="SIFMe.Forms.planer_form"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIFMe.Forms"
             xmlns:objects="clr-namespace:SIFMe.Objects"
             xmlns:classes="clr-namespace:SIFMe.ExternalClasses"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Height="450" Width="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIFMe;component/Styles/planer_style.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Border Margin="25,0,0,0" Width="25" Style="{StaticResource TopBorder}"></Border>
        <Border x:Name="Dragger_" Width="50" Height="50" Style="{StaticResource Dragger}"></Border>
        <Border Name="BottomBorder" Grid.Column="2" Style="{StaticResource BotomBorder}"></Border>
        <Canvas Grid.Column="1" Background="{StaticResource GreenEdgeGradientBrush}" Opacity="0.8" IsHitTestVisible="False"></Canvas>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Height="450" HorizontalAlignment="Center">
            <Border Name="EditPanel" Width="250" Height="410" Background="#6666FF" CornerRadius="20" Margin="0,0,20,0" Visibility="Collapsed">
                <Canvas>
                    <Button Content="X" Background="#440088" BorderBrush="Transparent" Width="30" Height="30" Canvas.Top="10" Canvas.Right="10" Click="EditorClose"></Button>
                    <StackPanel Canvas.Top="10">
                        <TextBlock Text=" Название" Height="22" Width="200" Foreground="White" FontSize="20"></TextBlock>
                        <TextBox Text="{Binding title}" FontSize="18" Width="200"></TextBox>
                        <TextBlock Text=" Описание" Height="22" Width="200" Foreground="White" FontSize="20"></TextBlock>
                        <TextBox Text="{Binding description}" FontSize="18" Width="200" Height="260" TextWrapping="Wrap"></TextBox>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <ComboBox Name="TypeSelector" Width="100" SelectedIndex="{Binding play_type}"></ComboBox>
                            <TextBox Text="{Binding interval, TargetNullValue='00:00'}" Width="100"></TextBox>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Сохранить" Background="#440088" BorderBrush="Transparent" Width="115" Height="22" Canvas.Bottom="10" Canvas.Left="10" Click="SaveNotification"></Button>
                    <Button Name="DelBtn" Content="Удалить" Background="#440088" BorderBrush="Transparent" Width="90" Height="22" Canvas.Bottom="10" Canvas.Right="10" Click="DeleteNotification"></Button>
                </Canvas>
            </Border>
            <Button Name="AddButton" Content="+" FontSize="50" BorderBrush="#6666FF" BorderThickness="10" Width="100" Height="100" Margin="0,0,20,0" Click="NewNotification"></Button>
            <ListView Name="ResultList" Width="250" BorderBrush="Transparent" VerticalAlignment="Center" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <objects:notification_view MouseDoubleClick="UpdateNotification"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock Name="Placeholder" Text="У вас нет активных напоминаний" Width="250" Height="50" FontSize="20" TextWrapping="Wrap" TextAlignment="Center"></TextBlock>
        </StackPanel>
        <Canvas Background="{StaticResource TiledTextureBrush}" Grid.Column="1" IsHitTestVisible="False"></Canvas>
    </Grid>
</classes:form_controls>
