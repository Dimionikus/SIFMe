<UserControl x:Class="SIFMe.Objects.form_sellector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIFMe.Objects"
             mc:Ignorable="d" 
             d:Height="50" d:Width="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIFMe;component/Styles/selector_style.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <StackPanel Orientation="Horizontal" IsHitTestVisible="True">
            <Border Name="CreaF0" Height="50" Width="50" MouseLeftButtonUp="Create">
                <Border Width="30" Height="30" Style="{StaticResource AddForm1}">
                    <Image Source="pack://application:,,,/SIFMe;component/Sprites/browsecreatericon.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></Image>
                </Border>
                <Border.DataContext>0</Border.DataContext>
            </Border>
            <Border Name="CreaF1" Height="50" Width="50" MouseLeftButtonUp="Create">
                <Border Width="30" Height="30" Style="{StaticResource AddForm2}">
                    <Image Source="pack://application:,,,/SIFMe;component/Sprites/planercreatericon.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></Image>
                </Border>
                <Border.DataContext>1</Border.DataContext>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
