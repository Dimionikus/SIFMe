<UserControl x:Class="SIFMe.Objects.forms_bar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIFMe.Objects"
             mc:Ignorable="d" 
             d:Height="450" d:Width="60">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIFMe;component/Styles/selector_style.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Height="450" Width="60">
        <Canvas>
            <Border Name="AddButton" Width="35" Height="35" Canvas.Left="13" Canvas.Top="8" MouseLeftButtonUp="OpenCloseSelector" Style="{StaticResource OCButon}" IsHitTestVisible="True">
                <Border.RenderTransform>
                    <RotateTransform Angle="0"></RotateTransform>
                </Border.RenderTransform>
            </Border>
        </Canvas>
        <StackPanel Name="Stacks"  Orientation="Vertical" CanHorizontallyScroll="False" CanVerticallyScroll="True" Margin="0,50,0,0">
            
        </StackPanel>
    </Grid>
</UserControl>
