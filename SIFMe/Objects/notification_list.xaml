<UserControl x:Class="SIFMe.Objects.notification_list"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIFMe.Objects"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="300" Width="300" Height="250">
    <UserControl.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="GreenEdgeGradientBrush"
                 StartPoint="0,1" EndPoint="0,0" Opacity="0.9">
                <GradientStop Color="#6666FF" Offset="0"/>
                <GradientStop Color="#440088" Offset="0.1"/>
                <GradientStop Color="#440088" Offset="0.9"/>
                <GradientStop Color="#6666FF" Offset="1"/>
            </LinearGradientBrush>
            <ImageBrush x:Key="TiledTextureBrush"
        ImageSource="pack://application:,,,/SIFMe;component/Sprites/noise_texture.png"
        TileMode="Tile"
        Viewport="0,0,5,5"
        ViewportUnits="Absolute"
        Stretch="None"/>
            <LinearGradientBrush x:Key="Gradient1" StartPoint="0.5 0" EndPoint="0.5 1">
                <GradientStop Offset="0.1" Color="#5a5a5a"></GradientStop>
                <GradientStop Offset="0.25" Color="#6a6a6a"></GradientStop>
                <GradientStop Offset="0.4" Color="#7a7a7a"></GradientStop>
                <GradientStop Offset="0.75" Color="#6a6a6a"></GradientStop>
                <GradientStop Offset="1" Color="#5a5a5a"></GradientStop>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="Gradient2" StartPoint="0.5 0" EndPoint="0.5 1">
                <GradientStop Offset="0.1" Color="#1a1a1a"></GradientStop>
                <GradientStop Offset="0.25" Color="#2a2a2a"></GradientStop>
                <GradientStop Offset="0.4" Color="#3a3a3a"></GradientStop>
                <GradientStop Offset="0.75" Color="#2a2a2a"></GradientStop>
                <GradientStop Offset="1" Color="#1a1a1a"></GradientStop>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="BrushBorder" Color="#4a4a4a"></SolidColorBrush>
            <SolidColorBrush x:Key="CloseBorder" Color="#6a1a1a"></SolidColorBrush>
            <Style x:Key="TopBorder" TargetType="Border">
                <Setter Property="CornerRadius" Value="0,0,10,10"></Setter>
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
                <Setter Property="BorderThickness" Value="5,0,5,5"></Setter>
                <Setter Property="Background" Value="{StaticResource Gradient1}"></Setter>
            </Style>
            <Style x:Key="BotomBorder" TargetType="Border">
                <Setter Property="CornerRadius" Value="10,10,0,0"></Setter>
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
                <Setter Property="BorderThickness" Value="5,5,5,5"></Setter>
                <Setter Property="Background" Value="{StaticResource Gradient1}"></Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Canvas>
            <Button Name="OpenCloseBtn" Width="50" Height="50" Background="Transparent" BorderBrush="Transparent" Canvas.Bottom="0" Click="OpenClose" Visibility="Collapsed">
                <Canvas Width="50" Height="50">
                    <Image Width="50" Height="50" Source="pack://application:,,,/SIFMe;component/Sprites/planercreatericon.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></Image>
                    <TextBlock Name="Counter" Text="0" FontSize="20" FontFamily="Arial Black" Foreground="#FFDEAD" Canvas.Left="0" Canvas.Bottom="0">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="Black" Opacity="1"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Canvas>
            </Button>
        </Canvas>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="10"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
            </Grid.RowDefinitions>
            <Border Grid.Row="2" Style="{StaticResource TopBorder}" IsHitTestVisible="False"></Border>
            <Border Name="BottomBorder" Style="{StaticResource BotomBorder}" IsHitTestVisible="False"></Border>
            <Canvas Grid.Row="1" Background="{StaticResource GreenEdgeGradientBrush}" Opacity="0.8" IsHitTestVisible="False"></Canvas>
            <StackPanel VerticalAlignment="Center" Name="NotList" Grid.Row="1"></StackPanel>
            <Canvas Background="{StaticResource TiledTextureBrush}" Grid.Row="1" IsHitTestVisible="False"></Canvas>
        </Grid>
    </Grid>
</UserControl>
