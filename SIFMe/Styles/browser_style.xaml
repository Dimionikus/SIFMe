<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="Gradient1" StartPoint="0.5 0" EndPoint="0.5 1">
        <GradientStop Offset="0.1" Color="#5a5a5a"></GradientStop>
        <GradientStop Offset="0.25" Color="#6a6a6a"></GradientStop>
        <GradientStop Offset="0.4" Color="#7a7a7a"></GradientStop>
        <GradientStop Offset="0.75" Color="#6a6a6a"></GradientStop>
        <GradientStop Offset="1" Color="#5a5a5a"></GradientStop>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="BrushBorder" Color="#4a4a4a"></SolidColorBrush>
    <SolidColorBrush x:Key="CloseBorder" Color="#6a1a1a"></SolidColorBrush>
    <VisualBrush x:Key="DragImage" Stretch="Fill" TileMode="None">
        <VisualBrush.Visual>
            <Grid Width="50" Height="50">
                <Rectangle Fill="AliceBlue"></Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5 0" EndPoint="0.5 1">
                            <GradientStop Offset="0.1" Color="#c1c1c1"></GradientStop>
                            <GradientStop Offset="0.4" Color="#9a9a9a"></GradientStop>
                            <GradientStop Offset="1" Color="#c1c1c1"></GradientStop>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="pack://application:,,,/SIFMe;component/Sprites/dragdetector.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></ImageBrush>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </VisualBrush.Visual>
    </VisualBrush>
    <VisualBrush x:Key="IconPicture" Stretch="Fill" TileMode="None">
        <VisualBrush.Visual>
            <Grid Width="50" Height="50">
                <Rectangle Fill="AliceBlue"></Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5 0" EndPoint="0.5 1">
                            <GradientStop Offset="0.1" Color="#c1c1c1"></GradientStop>
                            <GradientStop Offset="0.4" Color="#9a9a9a"></GradientStop>
                            <GradientStop Offset="1" Color="#c1c1c1"></GradientStop>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="pack://application:,,,/SIFMe;component/Sprites/browsericon.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></ImageBrush>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </VisualBrush.Visual>
    </VisualBrush>
    <VisualBrush x:Key="ClosePicture" Stretch="Fill" TileMode="None">
        <VisualBrush.Visual>
            <Grid Width="50" Height="50">
                <Rectangle Fill="AliceBlue"></Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5 0" EndPoint="0.5 1">
                            <GradientStop Offset="0.1" Color="#c11111"></GradientStop>
                            <GradientStop Offset="0.4" Color="#9a1a1a"></GradientStop>
                            <GradientStop Offset="1" Color="#c11111"></GradientStop>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="pack://application:,,,/SIFMe;component/Sprites/closeicon.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></ImageBrush>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </VisualBrush.Visual>
    </VisualBrush>
    <Style x:Key="TopBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="10,0,0,10"></Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
        <Setter Property="BorderThickness" Value="5,5,0,5"></Setter>
        <Setter Property="Background" Value="{StaticResource Gradient1}"></Setter>
    </Style>
    <Style x:Key="BotomBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="0,10,10,0"></Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
        <Setter Property="BorderThickness" Value="0,5,5,5"></Setter>
        <Setter Property="Background" Value="{StaticResource Gradient1}"></Setter>
    </Style>
    <Style x:Key="Dragger" TargetType="Border">
        <Setter Property="CornerRadius" Value="10,0,0,10"></Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
        <Setter Property="BorderThickness" Value="7,7,7,7"></Setter>
        <Setter Property="Background" Value="{StaticResource DragImage}"></Setter>
    </Style>
    <Style x:Key="Icon" TargetType="Border">
        <Setter Property="CornerRadius" Value="10,10,10,10"></Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"></Setter>
        <Setter Property="BorderThickness" Value="7,7,7,7"></Setter>
        <Setter Property="Background" Value="{StaticResource IconPicture}"></Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="55" Duration="0:0:0.5" FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <ElasticEase/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="55" Duration="0:0:0.5" FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <ElasticEase/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="50" Duration="0:0:0.3" FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <ElasticEase/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="50" Duration="0:0:0.3" FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <ElasticEase/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>