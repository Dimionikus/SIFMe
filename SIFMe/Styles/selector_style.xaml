<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="g1" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#9f9f9f" Offset="0"/>
        <GradientStop Color="#9f9f9f" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="BaseButtonBrush" Color="AliceBlue"></SolidColorBrush>
    <VisualBrush x:Key="OCBrush">
        <VisualBrush.Visual>
            <Image Width="50" Height="50" Source="pack://application:,,,/SIFMe;component/Sprites/addbutton.png" RenderOptions.BitmapScalingMode="NearestNeighbor"></Image>
        </VisualBrush.Visual>
    </VisualBrush>
    <Storyboard x:Key="Popup">
        <DoubleAnimation Storyboard.TargetProperty="Width" To="45" Duration="0:0:0.5" FillBehavior="HoldEnd">
            <DoubleAnimation.EasingFunction>
                <ElasticEase/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Height" To="45" Duration="0:0:0.5" FillBehavior="HoldEnd">
            <DoubleAnimation.EasingFunction>
                <ElasticEase/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>
    <Storyboard x:Key="Popdown">
        <DoubleAnimation Storyboard.TargetProperty="Width" To="30" Duration="0:0:0.3" FillBehavior="HoldEnd">
            <DoubleAnimation.EasingFunction>
                <ElasticEase/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Height" To="30" Duration="0:0:0.3" FillBehavior="HoldEnd">
            <DoubleAnimation.EasingFunction>
                <ElasticEase/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>
    <Style x:Key="AddForm1" TargetType="Border">
        <Setter Property="Background" Value="#FF006600"/>
        <Setter Property="BorderBrush" Value="#FF66FF66"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderThickness" Value="5"/>
                <Trigger.EnterActions>
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace" Storyboard="{StaticResource Popup}"></BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace" Storyboard="{StaticResource Popdown}"></BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="AddForm2" TargetType="Border">
        <Setter Property="Background" Value="#440088"/>
        <Setter Property="BorderBrush" Value="#6666FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="25"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderThickness" Value="5"/>
                <Trigger.EnterActions>
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace" Storyboard="{StaticResource Popup}"></BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace" Storyboard="{StaticResource Popdown}"></BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="OCButon" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OCBrush}"/>
    </Style>
</ResourceDictionary>